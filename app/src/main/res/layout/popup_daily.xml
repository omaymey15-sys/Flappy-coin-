<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="#2a2a3e"
    android:gravity="center"
    android:layout_margin="16dp">

    <TextView
        android:id="@+id/tvDailyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📆 Calendrier"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:weightSum="7">

        <Button android:id="@+id/day1" android:layout_width="50dp" android:layout_height="50dp" android:text="1" android:textSize="18sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/day2" android:layout_width="50dp" android:layout_height="50dp" android:text="2" android:textSize="18sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/day3" android:layout_width="50dp" android:layout_height="50dp" android:text="3" android:textSize="18sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/day4" android:layout_width="50dp" android:layout_height="50dp" android:text="4" android:textSize="18sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/day5" android:layout_width="50dp" android:layout_height="50dp" android:text="5" android:textSize="18sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/day6" android:layout_width="50dp" android:layout_height="50dp" android:text="6" android:textSize="18sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/day7" android:layout_width="50dp" android:layout_height="50dp" android:text="7" android:textSize="18sp" android:layout_margin="4dp"/>
    </LinearLayout>
</LinearLayout>