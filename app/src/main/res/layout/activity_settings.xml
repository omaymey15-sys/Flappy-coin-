<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1a1a1a">

    <TextView
        android:text="⚙️ PARAMÈTRES"
        android:textSize="28sp"
        android:textColor="#FFD700"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"
        android:gravity="center"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Son -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#2a2a3e"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:text="🔊 Son"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>

                <Switch
                    android:id="@+id/swSound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- Vibration -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#2a2a3e"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:text="📳 Vibrations"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>

                <Switch
                    android:id="@+id/swVibration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <TextView
                android:text="Infos Profil"
                android:textColor="#FFD700"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvUsername"
                android:text="Utilisateur: Guest"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="#2a2a3e"
                android:padding="12dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvCountry"
                android:text="Pays: France"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="#2a2a3e"
                android:padding="12dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvLanguage"
                android:text="Langue: Français"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="#2a2a3e"
                android:padding="12dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvCurrency"
                android:text="Devise: EUR"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="#2a2a3e"
                android:padding="12dp"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

    </ScrollView>

    <Button
        android:id="@+id/btnBack"
        android:text="← Retour"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#4169E1"
        android:textColor="#FFFFFF"/>

</LinearLayout>